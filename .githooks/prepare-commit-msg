#!/bin/sh
# Strip Cursor co-author trailers so GitHub never credits cursoragent from commit messages.
msg=$1
[ -n "$msg" ] && [ -f "$msg" ] || exit 0
tmp=$(mktemp "${TMPDIR:-/tmp}/git-msg.XXXXXX") || exit 0
grep -v -i -E '^Co-authored-by:.*(cursoragent|cursor\.com|@cursor)' "$msg" >"$tmp" && mv "$tmp" "$msg" || rm -f "$tmp"
exit 0
